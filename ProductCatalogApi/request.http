@baseUrl = http://localhost:5069
@productId = 342e4097-2173-43a2-ae01-c4c0fb695524

### GET all products
GET {{baseUrl}}/api/products

###

### GET product by id
GET {{baseUrl}}/api/products/{{productId}}

###

### POST - create product
POST {{baseUrl}}/api/products
Content-Type: application/json

{
    "name": "iPhone 15",
    "description": "Apple iPhone 15 128GB",
    "price": "999"
}

###

### PUT - replace entire product
PUT {{baseUrl}}/api/products/{{productId}}
Content-Type: application/json

{
    "name": "iPhone 15 Pro",
    "description": "Apple iPhone 15 Pro 256GB",
    "price": "1199"
}

###

### PATCH - update price only
PATCH {{baseUrl}}/api/products/{{productId}}
Content-Type: application/json

[
    { "op": "replace", "path": "/price", "value": "899" }
]

###

### DELETE product
DELETE {{baseUrl}}/api/products/{{productId}}

###

### GET non-existent product (expect 404)
GET {{baseUrl}}/api/products/non-existent-id
